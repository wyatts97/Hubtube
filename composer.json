{
    "name": "hubtube/cms",
    "type": "project",
    "description": "HubTube - Adult Video Tube CMS",
    "keywords": ["laravel", "cms", "video", "tube", "streaming"],
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "ext-redis": "*",
        "awcodes/overlook": "^4.0",
        "bezhansalleh/filament-google-analytics": "^3.3",
        "bezhansalleh/filament-shield": "^4.0",
        "croustibat/filament-jobs-monitor": "*",
        "filafly/filament-phosphor-icons": "^2.2",
        "filament/filament": "^5.0",
        "finity-labs/fin-mail": "^1.8.1",
        "guzzlehttp/guzzle": "^7.8",
        "inertiajs/inertia-laravel": "^2.0",
        "intervention/image": "^3.0",
        "laravel/cashier": "^15.0",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.24",
        "laravel/reverb": "^1.0",
        "laravel/sanctum": "^4.0",
        "laravel/scout": "^10.8",
        "laravel/socialite": "^5.12",
        "laravel/tinker": "^2.9",
        "league/csv": "^9.28",
        "league/flysystem-aws-s3-v3": "^3.0",
        "leandrocfe/filament-apex-charts": "^5.0",
        "leek/filament-right-click": "1.3",
        "livewire/livewire": "^4.0",
        "martin6363/filament-sidebar-resize": "1.0",
        "meilisearch/meilisearch-php": "^1.6",
        "mradder/filament-logger": "^1.0",
        "openplain/filament-shadcn-theme": "^1.0",
        "sentry/sentry-laravel": "^4.20",
        "socialiteproviders/reddit": "^4.2",
        "spatie/laravel-activitylog": "^4.8",
        "spatie/laravel-medialibrary": "^11.4",
        "spatie/laravel-permission": "^6.4",
        "stichoza/google-translate-php": "^5.1",
        "tightenco/ziggy": "^2.0"
    },
    "require-dev": {
        "beyondcode/laravel-query-detector": "^2.1",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "~3.0",
        "laravel/pint": "^1.14",
        "laravel/sail": "^1.28",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "~2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan livewire:publish --assets --ansi",
            "@php artisan filament:assets --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "test": "pest",
        "lint": "pint",
        "analyse": "phpstan analyse"
    },

    "extra": {
        "laravel": {
            "dont-discover": [
                    "sentry/sentry-laravel"
                ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "audit": {
            "block-insecure": false
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
